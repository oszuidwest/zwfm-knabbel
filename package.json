{
  "name": "zwfm-knabbel",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "types:generate": "openapi-typescript https://raw.githubusercontent.com/oszuidwest/zwfm-babbel/main/openapi.yaml -o src/lib/types/api.ts",
    "types:check": "openapi-typescript https://raw.githubusercontent.com/oszuidwest/zwfm-babbel/main/openapi.yaml -o .api-types-check.ts && prettier --write --ignore-path .prettierignore .api-types-check.ts > /dev/null && diff -q src/lib/types/api.ts .api-types-check.ts; EXIT=$?; rm -f .api-types-check.ts; if [ $EXIT -ne 0 ]; then echo 'Types out of sync! Run: npm run types:generate && npm run format'; exit 1; fi",
    "check-all": "npm run check && npm run lint && npm run format:check && npm run types:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.2.6"
  },
  "dependencies": {
    "@lucide/svelte": "^1.7.0",
    "daisyui": "^5.5.19",
    "zod": "^3.25.76"
  }
}
